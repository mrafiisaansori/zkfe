# Base URL backend Node.js (/pos-backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Basic Auth backend (gate seluruh API & Swagger)
NEXT_PUBLIC_BASIC_AUTH_USERNAME=admin
NEXT_PUBLIC_BASIC_AUTH_PASSWORD=rahasia

# Cloudflare Turnstile SITE KEY.
# Kosongkan di lokal -> Turnstile NONAKTIF (dev lancar).
# Isi HANYA di production (saat build) -> widget muncul di semua form publik.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
